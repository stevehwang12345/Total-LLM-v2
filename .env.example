# ==============================
# Total-LLM v2 환경 변수 예시
# ==============================

# [공통] Hugging Face 모델 다운로드 토큰 (필요 시 설정)
HUGGING_FACE_HUB_TOKEN=

# [LLM] vLLM OpenAI 호환 엔드포인트
VLLM_BASE_URL=http://localhost:9000/v1
# [LLM] 텍스트 생성 모델 이름
LLM_MODEL_NAME=Qwen/Qwen3.5-9B

# [VLM] 비전-언어 모델 엔드포인트 (기본적으로 LLM과 동일)
VLM_BASE_URL=http://localhost:9000/v1
# [VLM] 비전-언어 모델 이름 (기본적으로 LLM과 동일)
VLM_MODEL_NAME=Qwen/Qwen3.5-9B

# [임베딩] 문서 벡터화 모델 이름
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
# [임베딩] 임베딩 모델 실행 디바이스 (cpu/cuda)
EMBEDDING_DEVICE=cpu

# [Qdrant] 벡터 데이터베이스 호스트
QDRANT_HOST=localhost
# [Qdrant] 벡터 데이터베이스 포트
QDRANT_PORT=6333
# [Qdrant] 문서 컬렉션 이름
QDRANT_COLLECTION_NAME=documents
# [Qdrant] 벡터 차원 크기
QDRANT_VECTOR_SIZE=1024

# [PostgreSQL] 데이터베이스 호스트
POSTGRES_HOST=localhost
# [PostgreSQL] 데이터베이스 포트
POSTGRES_PORT=5434
# [PostgreSQL] 데이터베이스 이름
POSTGRES_DB=total_llm
# [PostgreSQL] 데이터베이스 사용자명
POSTGRES_USER=total_llm
# [PostgreSQL] 데이터베이스 비밀번호
POSTGRES_PASSWORD=total_llm_dev

# [Redis] 캐시/세션 저장소 호스트
REDIS_HOST=localhost
# [Redis] 캐시/세션 저장소 포트
REDIS_PORT=6381
# [Redis] 비밀번호 (미사용 시 빈 값)
REDIS_PASSWORD=

# [API] FastAPI 바인딩 호스트
API_HOST=0.0.0.0
# [API] FastAPI 바인딩 포트
API_PORT=9002
# [API] 허용할 CORS Origin 목록 (JSON 배열 또는 쉼표 구분 문자열)
CORS_ORIGINS=["http://localhost:9004","http://localhost:5173"]

# [인증] JWT 서명 키 (운영 환경에서는 반드시 강력한 값으로 변경)
JWT_SECRET=change-me-in-production
# [인증] JWT 알고리즘
JWT_ALGORITHM=HS256
# [인증] JWT 만료 시간(분)
JWT_EXPIRE_MINUTES=60
